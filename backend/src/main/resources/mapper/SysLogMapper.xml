<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.straykun.svd.svdsys.mapper.SysLogMapper">

    <resultMap id="SysLogResultMap" type="com.straykun.svd.svdsys.domain.SysLog">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="operation" column="operation"/>
        <result property="method" column="method"/>
        <result property="params" column="params"/>
        <result property="time" column="time"/>
        <result property="ip" column="ip"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.straykun.svd.svdsys.domain.SysLog" useGeneratedKeys="true"
            keyProperty="id">
        insert into sys_log (username, operation, method, params, time, ip, create_time)
        values (#{username}, #{operation}, #{method}, #{params}, #{time}, #{ip}, now())
    </insert>

    <select id="selectPage" resultMap="SysLogResultMap">
        select id, username, operation, method, params, time, ip, create_time
        from sys_log
        <where>
            <if test="username != null and username != ''">
                and username like concat('%', #{username}, '%')
            </if>
            <if test="startDate != null">
                and create_time &gt;= #{startDate}
            </if>
            <if test="endDate != null">
                and create_time &lt;= #{endDate}
            </if>
        </where>
        order by create_time desc, id desc
        limit #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        select count(1)
        from sys_log
        <where>
            <if test="username != null and username != ''">
                and username like concat('%', #{username}, '%')
            </if>
            <if test="startDate != null">
                and create_time &gt;= #{startDate}
            </if>
            <if test="endDate != null">
                and create_time &lt;= #{endDate}
            </if>
        </where>
    </select>

</mapper>

